            "url": {
              "raw": "{{base_url}}/users/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "register"
              ]
            },
            "description": "Crea un nuevo usuario en el sistema. \n\n⚠️ Ojo de Tester: Si corres este request dos veces seguidas, la API te dará un Error 400 porque el correo ya existe. ¡Recuerda cambiar el número del correo (ej. 002, 003) en el Body para tu siguiente prueba!"
          },
          "response": []
